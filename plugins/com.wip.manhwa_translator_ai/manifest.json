{
    "manifestVersion": "1.0",
    "plugin": {
        "id": "com.wip.manhwa_translator_ai",
        "name": "Manhwa Translator AI",
        "version": "1.3.7",
        "description": "Translate text from Manhwa/Manga into Italian using Google AI via Koog"
    },
    "requirements": {
        "minMemoryMb": 128,
        "minExecutionTimeMs": 10
    },
    "capabilities": [
        {
            "name": "translate",
            "description": "Translates a list of strings into Italian using Google AI",
            "parameters": {
                "input": {
                    "description": "List of text strings to translate",
                    "type": {
                        "type": "array",
                        "items": {
                            "type": "primitive",
                            "primitiveType": "STRING"
                        }
                    },
                    "required": true
                },
                "dictionary": {
                    "description": "Dictionary of words/actions to keep the translation coherent",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "STRING"
                    }
                },
                "model": {
                    "defaultValue": "GEMMA_31B",
                    "description": "The Gemini Model ID to use",
                    "type": {
                        "type": "enum",
                        "className": "com.wip.manhwaTranslatorAI.AIModel",
                        "options": [
                            "GEMMA_26B",
                            "GEMMA_31B",
                            "GEMINI_3_5_FLASH",
                            "GEMINI_3_1_FLASH_LITE",
                            "LM_STUDIO"
                        ]
                    },
                    "required": true
                },
                "pageNames": {
                    "defaultValue": [],
                    "description": "List of page names matching the input texts (from OCR)",
                    "type": {
                        "type": "array",
                        "items": {
                            "type": "primitive",
                            "primitiveType": "STRING"
                        }
                    }
                },
                "inputFolder": {
                    "description": "Path to the folder containing the images",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "STRING"
                    },
                    "required": true,
                    "semanticTypes": [
                        {
                            "namespace": "path",
                            "name": "folder",
                            "variant": null
                        }
                    ],
                    "role": "INPUT_LOCATION"
                },
                "outputDir": {
                    "description": "Directory to save translation result",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "STRING"
                    },
                    "required": true,
                    "semanticTypes": [
                        {
                            "namespace": "path",
                            "name": "folder",
                            "variant": null
                        }
                    ],
                    "role": "OUTPUT_LOCATION",
                    "autogeneratedPattern": ""
                },
                "tempSummaryDir": {
                    "description": "Temporary directory for summary images",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "STRING"
                    },
                    "required": true,
                    "semanticTypes": [
                        {
                            "namespace": "path",
                            "name": "folder",
                            "variant": null
                        }
                    ],
                    "role": "OUTPUT_LOCATION",
                    "autogeneratedPattern": ""
                },
                "useContextImages": {
                    "defaultValue": false,
                    "description": "Send images to AI for visual context (Requires Gemini 1.5/Gemma)",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "BOOLEAN"
                    }
                },
                "generateChapterSummary": {
                    "defaultValue": true,
                    "description": "Generate a global summary context from all chapter images using Gemini 3.1 Flash Lite",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "BOOLEAN"
                    }
                },
                "save": {
                    "defaultValue": true,
                    "description": "Save the translation result in a json",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "BOOLEAN"
                    }
                }
            },
            "returnType": {
                "type": "array",
                "items": {
                    "type": "primitive",
                    "primitiveType": "STRING"
                }
            },
            "outputs": [
                {
                    "name": "result",
                    "description": "",
                    "type": {
                        "type": "array",
                        "items": {
                            "type": "primitive",
                            "primitiveType": "STRING"
                        }
                    }
                }
            ],
            "fileAccess": {
                "readsFiles": true,
                "writesFiles": true
            }
        },
        {
            "name": "translate_advanced_ocr",
            "description": "Translates an AdvancedOCRResult into Italian using Google AI",
            "parameters": {
                "inputOcr": {
                    "description": "The Advanced OCR Result to translate",
                    "type": {
                        "type": "object",
                        "className": "com.wip.common.models.AdvancedOCRResult",
                        "properties": {
                            "texts": {
                                "type": "array",
                                "items": {
                                    "type": "primitive",
                                    "primitiveType": "STRING"
                                }
                            },
