                "date": "2026-05-20",
                "categories": {
                    "Added": [
                        "Support for toolkit 1.5.1"
                    ]
                }
            },
            {
                "version": "2.0.2",
                "date": "2026-05-12",
                "categories": {
                    "Added": [
                        "Support for toolkit 1.5.0"
                    ]
                }
            },
            {
