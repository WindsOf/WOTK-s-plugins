{
    "manifestVersion": "1.0",
    "plugin": {
        "id": "com.wip.ocr_ia",
        "name": "OCR IA",
        "version": "2.4.6",
        "description": "Advanced OCR plugin using Google AI, Anthropic, OpenAI, and LMStudio via Koog"
    },
    "requirements": {
        "minMemoryMb": 128,
        "minExecutionTimeMs": 10
    },
    "capabilities": [
        {
            "name": "ocr",
            "description": "Performs basic OCR on an image or a folder of images",
            "parameters": {
                "input": {
                    "description": "Path to image or folder",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "STRING"
                    },
                    "required": true,
                    "semanticTypes": [
                        {
                            "namespace": "path",
                            "name": "folder",
                            "variant": null
                        }
                    ],
                    "role": "INPUT_LOCATION"
                },
                "save": {
                    "defaultValue": true,
                    "description": "Save output to a .txt file alongside each image",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "BOOLEAN"
                    },
                    "required": true
                },
                "outputDir": {
                    "description": "Custom output directory",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "STRING"
                    },
                    "required": true,
                    "semanticTypes": [
                        {
                            "namespace": "path",
                            "name": "folder",
                            "variant": null
                        }
                    ],
                    "role": "OUTPUT_LOCATION",
                    "autogeneratedPattern": ""
                },
                "useStructuredOutput": {
                    "defaultValue": false,
                    "description": "Whether to use native structured output (might not be supported by all models)",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "BOOLEAN"
                    },
                    "required": true
                },
                "saveThinking": {
                    "defaultValue": false,
                    "description": "Whether to save the thinking inside the json",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "BOOLEAN"
                    },
                    "required": true
                },
                "model": {
                    "defaultValue": "GEMMA_26B",
                    "description": "The AI Model to use",
                    "type": {
                        "type": "enum",
                        "className": "com.wip.common.models.AIModel",
                        "options": [
                            "GEMMA_26B",
                            "GEMMA_31B",
                            "GEMINI_1_5_PRO",
                            "GEMINI_2_5_PRO",
                            "GEMINI_3_1_FLASH_LITE",
                            "CLAUDE_3_5_SONNET",
                            "GPT_4O",
                            "LM_STUDIO"
                        ]
                    },
                    "required": true
                }
            },
            "returnType": {
                "type": "object",
                "className": "com.wip.common.models.OCRResult",
                "properties": {
                    "texts": {
                        "type": "array",
                        "items": {
                            "type": "primitive",
                            "primitiveType": "STRING"
                        }
                    },
                    "bb": {
                        "type": "array",
                        "items": {
                            "type": "array",
                            "items": {
                                "type": "primitive",
                                "primitiveType": "DOUBLE"
                            }
                        }
                    },
                    "pageNumbers": {
                        "type": "array",
                        "items": {
                            "type": "primitive",
                            "primitiveType": "INT"
                        }
                    },
                    "pageNames": {
                        "type": "array",
                        "items": {
                            "type": "primitive",
                            "primitiveType": "STRING"
                        }
                    },
                    "failedFiles": {
                        "type": "array",
                        "items": {
                            "type": "primitive",
                            "primitiveType": "STRING"
                        }
                    }
                }
            },
            "outputs": [
                {
                    "name": "result",
                    "description": "",
                    "type": {
                        "type": "object",
                        "className": "com.wip.common.models.OCRResult",
                        "properties": {
                            "texts": {
                                "type": "array",
                                "items": {
                                    "type": "primitive",
                                    "primitiveType": "STRING"
                                }
                            },
                            "bb": {
                                "type": "array",
                                "items": {
                                    "type": "array",
                                    "items": {
                                        "type": "primitive",
                                        "primitiveType": "DOUBLE"
                                    }
                                }
                            },
                            "pageNumbers": {
                                "type": "array",
                                "items": {
                                    "type": "primitive",
                                    "primitiveType": "INT"
                                }
                            },
                            "pageNames": {
                                "type": "array",
                                "items": {
                                    "type": "primitive",
                                    "primitiveType": "STRING"
                                }
                            },
                            "failedFiles": {
                                "type": "array",
                                "items": {
                                    "type": "primitive",
                                    "primitiveType": "STRING"
                                }
                            }
                        }
                    }
                }
            ],
            "fileAccess": {
                "readsFiles": true,
                "writesFiles": true
            }
        },
        {
            "name": "advanced_ocr",
            "description": "Performs advanced OCR extracting exact balloon and text boxes, shapes, text orientation, sparsity, and color.",
