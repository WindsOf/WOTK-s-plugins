{
    "manifestVersion": "1.0",
    "plugin": {
        "id": "com.wip.slicer",
        "name": "Slicer",
        "version": "1.1.6",
        "description": "A plugin that provides vertical images sliding capabilities for manhwa."
    },
    "requirements": {
        "minMemoryMb": 128,
        "minExecutionTimeMs": 10
    },
    "capabilities": [
        {
            "name": "slicer",
            "description": "Slices a list of images",
            "parameters": {
                "folderPath": {
                    "description": "List of items to slice",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "STRING"
                    },
                    "required": true,
                    "semanticTypes": [
                        {
                            "namespace": "path",
                            "name": "folder",
                            "variant": null
                        }
                    ],
                    "role": "INPUT_LOCATION"
                },
                "outputFolderPath": {
                    "description": "Output folder path",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "STRING"
                    },
                    "required": true,
                    "semanticTypes": [
                        {
                            "namespace": "path",
                            "name": "folder",
                            "variant": null
                        }
                    ],
                    "role": "OUTPUT_LOCATION",
                    "autogeneratedPattern": "{folderPath}/sliced/",
                    "isDestructive": true
                },
                "minHeight": {
                    "defaultValue": 1000,
                    "description": "Minimum height",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "INT"
                    },
                    "required": true
                },
                "desiredHeight": {
                    "defaultValue": 10000,
                    "description": "Desired Height",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "INT"
                    },
                    "required": true
                },
                "maxHeight": {
                    "defaultValue": 10000,
                    "description": "Maximum Height",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "INT"
                    },
                    "required": true
                },
                "prioritizeSmallerImages": {
                    "defaultValue": true,
                    "description": "Prioritize smaller",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "BOOLEAN"
                    },
                    "required": true
                },
                "cutTolerance": {
                    "defaultValue": 5,
                    "description": "Cut tolerance",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "INT"
                    },
                    "required": true
                }
            },
            "returnType": {
                "type": "primitive",
                "primitiveType": "UNIT"
            },
            "fileAccess": {
                "readsFiles": true,
                "writesFiles": true,
                "isDestructive": true
            }
        },
        {
            "name": "Max distance for cuts",
            "description": "Analyzes row variances and determines the biggest section without cuts",
            "parameters": {
                "folderPath": {
                    "description": "List of items to slice",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "STRING"
                    },
                    "required": true,
                    "semanticTypes": [
                        {
                            "namespace": "path",
                            "name": "folder",
                            "variant": null
                        }
                    ],
                    "role": "INPUT_LOCATION"
                },
                "cutTolerance": {
                    "defaultValue": 5,
                    "description": "Cut tolerance",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "INT"
                    },
                    "required": true
                }
            },
            "returnType": {
                "type": "primitive",
                "primitiveType": "INT"
            },
            "outputs": [
                {
                    "name": "result",
                    "description": "",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "INT"
                    }
                }
            ],
            "fileAccess": {
                "readsFiles": true
            }
        }
    ]
}