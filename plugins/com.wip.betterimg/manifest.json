{
    "manifestVersion": "1.0",
    "plugin": {
        "id": "com.wip.betterimg",
        "name": "BetterIMG",
        "version": "2.0.6",
        "description": "A plugin that processes images using the BetterIMG CLI tool."
    },
    "requirements": {
        "minMemoryMb": 128,
        "minExecutionTimeMs": 10
    },
    "capabilities": [
        {
            "name": "Image Processor",
            "description": "Process a folder of images using BetterIMG CLI",
            "parameters": {
                "folder": {
                    "description": "Folder to process",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "STRING"
                    },
                    "required": true,
                    "semanticTypes": [
                        {
                            "namespace": "path",
                            "name": "folder",
                            "variant": null
                        }
                    ],
                    "role": "INPUT_LOCATION"
                },
                "width": {
                    "defaultValue": 940,
                    "description": "Output width in pixels",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "INT"
                    },
                    "required": true
                },
                "grain": {
                    "defaultValue": 5,
                    "description": "Grain level for processing",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "INT"
                    },
                    "required": true
                },
                "outputFormat": {
                    "defaultValue": "WEBP",
                    "description": "Output image format",
                    "type": {
                        "type": "enum",
                        "className": "com.wip.betterimg.OutputFormat",
                        "options": [
                            "PNG",
                            "WEBP"
                        ]
                    },
                    "required": true
                },
                "outFolder": {
                    "description": "Output folder",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "STRING"
                    },
                    "required": true,
                    "semanticTypes": [
                        {
                            "namespace": "path",
                            "name": "folder",
                            "variant": null
                        }
                    ],
                    "role": "OUTPUT_LOCATION",
                    "autogeneratedPattern": ""
                },
                "resumeState": {
                    "description": "",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "ANY"
                    }
                }
            },
            "returnType": {
                "type": "primitive",
                "primitiveType": "STRING"
            },
            "outputs": [
                {
                    "name": "result",
                    "description": "",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "STRING"
                    }
                }
            ],
            "isPausable": true,
            "fileAccess": {
                "readsFiles": true,
                "writesFiles": true
            }
        },
        {
            "name": "Image Processor with Scaling",
            "description": "Process a folder of images using BetterIMG CLI with scaling",
            "parameters": {
                "folder": {
                    "description": "Folder to process",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "STRING"
                    },
                    "required": true,
                    "semanticTypes": [
                        {
                            "namespace": "path",
                            "name": "folder",
                            "variant": null
                        }
                    ],
                    "role": "INPUT_LOCATION"
                },
                "width": {
                    "defaultValue": "x1",
                    "description": "Output width multiplier",
                    "type": {
                        "type": "enum",
                        "className": "com.wip.betterimg.Widths",
                        "options": [
                            "x1",
                            "x2",
                            "x4",
                            "x8"
                        ]
                    },
                    "required": true
                },
                "grain": {
                    "defaultValue": 5,
                    "description": "Grain level for processing",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "INT"
                    },
                    "required": true
                },
                "outputFormat": {
                    "defaultValue": "WEBP",
                    "description": "Output image format",
                    "type": {
                        "type": "enum",
                        "className": "com.wip.betterimg.OutputFormat",
                        "options": [
                            "PNG",
                            "WEBP"
                        ]
                    },
                    "required": true
                },
                "outFolder": {
                    "description": "Output folder",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "STRING"
                    },
                    "required": true,
                    "semanticTypes": [
                        {
                            "namespace": "path",
                            "name": "folder",
                            "variant": null
                        }
                    ],
                    "role": "OUTPUT_LOCATION",
                    "autogeneratedPattern": ""
                },
                "resumeState": {
                    "description": "",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "ANY"
                    }
                }
            },
            "returnType": {
                "type": "primitive",
                "primitiveType": "STRING"
            },
            "outputs": [
                {
                    "name": "result",
                    "description": "",
                    "type": {
                        "type": "primitive",
                        "primitiveType": "STRING"
                    }
                }
            ],
            "isPausable": true,
            "fileAccess": {
                "readsFiles": true,
                "writesFiles": true
            }
        }
    ],
    "changelog": {
        "releases": [
